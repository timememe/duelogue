extends RefCounted

## DUELOGUE — СОБЫТИЯ ЗАБЕГА (§6 «Скандал / Интервью»): контракт данных не-боевой сцены
## и мини-реестр плейсхолдеров. Событие = мини-диалог на 3–5 реплик + 2–3 выбора; эффект
## выбора — словарь для run_state.apply_effects (валюта событий §4: репутация ↔ гонорар,
## позже карты/инфа). Чистые данные, без состояния.
##
## Будущее: контент отдаёт narrative_engine (мастер-колода тем, §7.3) — структура события
## уже его словарь: реестр заменится генератором, контракт не изменится. Тем же движком
## события получат пошаговую подачу реплик (пока панель показывает их разом).

## Событие: {title, lines: [String], choices: [{label, effects: Dictionary, outro}]}.
const EVENTS := {
	"scandal_interview": {
		"title": "Скандальное интервью",
		"lines": [
			"Продюсер ток-шоу ловит вас в коридоре: «Один жареный эфир. Скажешь на камеру, что твой оппонент — клоун. Платим сразу.»",
			"Красный огонёк камеры уже смотрит на вас.",
			"Контракт этого не запрещает. Совесть — не пункт контракта.",
		],
		"choices": [
			{"label": "Сказать в камеру", "effects": {"rep": -1, "fee": 2},
				"outro": "Ролик разлетелся за час. Счёт пополнен, осадок остался."},
			{"label": "Улыбнуться и пройти мимо", "effects": {},
				"outro": "Продюсер пожимает плечами: «Найдём кого попроще.» Вы остались собой."},
			{"label": "Переиграть: эфир — но на ваших условиях", "effects": {"fee": 1},
				"outro": "Вышло пресно, зато без грязи. Небольшой гонорар и рукопожатие."},
		],
	},
	"kuluar_whisper": {
		"title": "Кулуарный шёпот",
		"lines": [
			"Гримёрка. Человек с бейджем «технический партнёр» понижает голос.",
			"«Список тезисов вашего следующего оппонента. Почти даром.»",
			"Бумага пахнет чужим принтером и чьей-то карьерой.",
		],
		"choices": [
			# Эффект intel (разведка §3.4) пока стаб — конверт ляжет на этот крючок.
			{"label": "Купить список", "effects": {"fee": -2},
				"outro": "Вы знаете, чем он откроет. Осталось решить, чем закроете вы."},
			{"label": "Отказаться", "effects": {},
				"outro": "Чистые руки, пустые карманы. Дверь гримёрки закрылась без скрипа."},
		],
	},
	"old_rival": {
		"title": "Старый соперник",
		"lines": [
			"В фойе — тот самый голос: «Всё продаёшь аргументы на вес?»",
			"Старый соперник. Пресса рядом мгновенно оживает.",
			"Диктофоны уже тянутся к вам через плечи охраны.",
		],
		"choices": [
			{"label": "Ответить великодушно", "effects": {"rep": 1},
				"outro": "Колонка вышла неожиданно тёплой. Репутация подлатана."},
			{"label": "Съязвить на камеры", "effects": {"rep": -1, "fee": 1},
				"outro": "Клип с перепалкой собрал просмотры. Букинг подкинул премию."},
		],
	},
}


static func pool() -> Array:
	return EVENTS.keys()


static func get_event(id: String) -> Dictionary:
	return EVENTS.get(id, {})
